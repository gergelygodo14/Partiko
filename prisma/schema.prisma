// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Ingredient {
  id        String   @id @default(cuid())
  name      String
  unit      String
  unitPrice Int
  order     Int      @default(0)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  entries   Entry[]
}

model Entry {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  date         DateTime
  quantity     Float
  createdAt    DateTime   @default(now())

  @@index([ingredientId, date])
}

model BillingPeriod {
  id       String   @id @default(cuid())
  from     DateTime
  to       DateTime
  closedAt DateTime @default(now())
}

model WeeklyMenu {
  id          String    @id @default(cuid())
  weekStart   DateTime  @unique
  days        Json
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Customer {
  id          String   @id @default(cuid())
  storeName   String
  companyName String
  createdAt   DateTime @default(now())
  orders      Order[]

  @@index([storeName, companyName])
}

model Order {
  id         String      @id @default(cuid())
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id])
  weekStart  DateTime
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  lines      OrderLine[]

  @@unique([customerId, weekStart])
}

model OrderLine {
  id       String  @id @default(cuid())
  orderId  String
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dayIndex Int
  letter   String
  isXl     Boolean @default(false)
  quantity Int

  @@unique([orderId, dayIndex, letter, isXl])
  @@index([orderId])
}

enum Supplier {
  SAJTFUTAR
  BAROMFIUDVAR
}

enum ProductStatus {
  PENDING
  CONFIRMED
}

enum InvoiceStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum PriceSource {
  EMAIL_PRICELIST
  INVOICE_PHOTO
  MANUAL
}

model Product {
  id                String             @id @default(cuid())
  name              String
  unit              String?
  // Hány alap-egység (pl. db) van egy "doboz"/"karton"/"csomag" mértékegységben
  // ennél a terméknél - ha be van állítva, az ilyen mértékegységű PriceObservation-ök
  // ára ennyivel osztva jelenik meg az ár-összehasonlításban, hogy összevethető legyen
  // egy másik beszállító darab-áras tételével.
  packSize          Int?
  status            ProductStatus      @default(PENDING)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  priceObservations PriceObservation[]

  @@index([status])
}

model PriceObservation {
  id           String      @id @default(cuid())
  productId    String
  product      Product     @relation(fields: [productId], references: [id])
  supplier     Supplier
  unitPrice    Int
  unit         String?
  observedDate DateTime
  source       PriceSource
  rawText      String?
  invoiceId    String?
  invoice      Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@index([productId, observedDate])
  @@index([supplier, observedDate])
}

model Invoice {
  id                String             @id @default(cuid())
  supplier          Supplier
  photoUrl          String
  photoBlobPathname String?
  status            InvoiceStatus      @default(UPLOADED)
  uploadedAt        DateTime           @default(now())
  processedAt       DateTime?
  rawExtraction     Json?
  summaryText       String?
  // Just the short "what changed price" block (buildHighlightSummary),
  // stored separately from summaryText so the /szamlak page can show the
  // latest invoice's price-change highlight in its own block at the top of
  // the page, without having to parse it back out of the full summary text.
  highlightText     String?
  errorMessage      String?
  priceObservations PriceObservation[]
  createdAt         DateTime           @default(now())
}

model PriceListImportRun {
  id             String   @id @default(cuid())
  emailMessageId String   @unique
  supplier       Supplier
  productCount   Int
  importedAt     DateTime @default(now())
}

// Catalog of real, previously-used dish names (seeded from the Drive
// menülisták corpus) that the weekly-menu "AI" suggestion button picks
// from - it never invents a name, only selects an existing one.
model Dish {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
